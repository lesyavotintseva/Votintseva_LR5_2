# БЛОК ОПИСАНИЯ СИСТЕМНЫХ ПАКЕТОВ
# Nix — функциональный пакетный менеджер с воспроизводимыми сборками.
# Все пакеты здесь устанавливаются на системном уровне (не через pip).
{ pkgs }: {
  deps = [
    # Интерактивная оболочка Replit для Python 3.10.
    # Обеспечивает корректный запуск REPL-сессии в Replit IDE.
    pkgs.replitPackages.prybar-python310
    # Утилита подсветки вывода в stderr.
    # Делает сообщения об ошибках красными в консоли Replit.
    pkgs.replitPackages.stderred
  ];
}