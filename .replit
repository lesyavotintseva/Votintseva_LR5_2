# БЛОК ОСНОВНЫХ НАСТРОЕК ЗАПУСКА
# Определяет язык, точку входа и команду запуска проекта
run = "python3 main.py" # Команда запуска при нажатии кнопки Run в Replit

# The primary language of the repl. There can be others, though!
language = "python3" # Первичный язык проекта
entrypoint = "main.py" # Файл, открываемый в редакторе по умолчанию
hidden = [
  "venv",
  ".config",
  "**/__pycache__",
  "**/.mypy_cache",
  "**/*.pyc",
] # Скрытые папки в файловом дереве IDE
modules = [
  "python-3.10",
] # Модуль среды выполнения: Python 3.10 (управляется Replit)

# БЛОК СИСТЕМНОГО ОКРУЖЕНИЯ NIX
# Определяет канал Nix для воспроизводимой сборки зависимостей
[nix]
channel = "stable-22_11"
packages = ["gdb"]

[env]

# Включите модульные тесты. Эта функция поддерживается только для некоторых языков.
[unitTest]
language = "python3"

# Это файлы, которые необходимо сохранить, если этот
# языковой шаблон используется в качестве базового языкового шаблона
# для репозиториев Python, импортированных из GitHub
[gitHubImport]
requiredFiles = [".replit", "replit.nix", ".config", "venv"]

# БЛОК КОНФИГУРАЦИИ ДЕПЛОЯ
# Команда запуска в production-окружении Replit Deployments
[deployment]
run = ["sh", "-c", "python3 main.py"]

# БЛОК МАППИНГА ПОРТОВ
# Проброс внутреннего порта 5000 на внешний порт 80
[[ports]]
localPort = 5000  # Порт, на котором слушает Flask внутри контейнера
externalPort = 80 # Внешний порт, доступный из браузера через прокси Replit

[agent]
expertMode = true

# БЛОК КОНФИГУРАЦИИ ВОРКФЛОУ (WORKFLOW)
# Определяет задачи запуска для кнопки Run и фонового выполнения
[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
